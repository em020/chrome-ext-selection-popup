{
  "manifest_version": 3,
  "name": "Selection Popup",
  "version": "1.0.0",
  "description": "Displays an action icon when text is selected on a webpage",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Selection Popup"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
